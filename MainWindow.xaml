<Window x:Class="TrikiPong.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Triki Pong" Height="580" Width="880"
        ResizeMode="CanMinimize"
        Background="{StaticResource WindowBackgroundBrush}"
        Loaded="OnWindowLoaded" Closing="OnWindowClosing"
        KeyDown="OnKeyDown" KeyUp="OnKeyUp" Focusable="True">
    <Grid Margin="20,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="&#x2190; Menu" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Left" Click="OnBackToMenuClick" />

            <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource SurfaceBorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="26,6">
                <TextBlock FontFamily="Consolas" FontSize="34" FontWeight="Bold">
                    <Run x:Name="AiScoreText" Text="0" Foreground="#FF5CC8FF" />
                    <Run Text="  :  " Foreground="#FF4A5170" />
                    <Run x:Name="PlayerScoreText" Text="0" Foreground="#FFFFC85C" />
                </TextBlock>
            </Border>
        </Grid>

        <Border Grid.Row="1" CornerRadius="14" BorderBrush="{StaticResource SurfaceBorderBrush}"
                BorderThickness="1.5" ClipToBounds="True"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#FF2E7BFF" BlurRadius="26" ShadowDepth="0" Opacity="0.22" />
            </Border.Effect>
            <Canvas x:Name="Court" Width="800" Height="440" ClipToBounds="True">
                <Canvas.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FF0A1020" Offset="0" />
                        <GradientStop Color="#FF0D1428" Offset="1" />
                    </LinearGradientBrush>
                </Canvas.Background>

                <!-- Center net -->
                <Rectangle Canvas.Left="399" Canvas.Top="0" Width="2" Height="440"
                           Fill="#22FFFFFF" StrokeDashArray="2 4" />
                <Line X1="400" Y1="0" X2="400" Y2="440" Stroke="#33FFFFFF" StrokeThickness="2"
                      StrokeDashArray="1 3" />
                <Ellipse Canvas.Left="360" Canvas.Top="180" Width="80" Height="80"
                         Stroke="#18FFFFFF" StrokeThickness="2" />

                <Rectangle x:Name="AiPaddle" Width="14" Height="90" Fill="#FF5CC8FF" RadiusX="7" RadiusY="7">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#FF5CC8FF" BlurRadius="18" ShadowDepth="0" Opacity="0.85" />
                    </Rectangle.Effect>
                </Rectangle>
                <Rectangle x:Name="PlayerPaddle" Width="14" Height="90" Fill="#FFFFC85C" RadiusX="7" RadiusY="7">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#FFFFC85C" BlurRadius="18" ShadowDepth="0" Opacity="0.85" />
                    </Rectangle.Effect>
                </Rectangle>
                <Ellipse x:Name="Ball" Width="14" Height="14" Fill="White">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#FFFFFFFF" BlurRadius="16" ShadowDepth="0" Opacity="0.9" />
                    </Ellipse.Effect>
                </Ellipse>
            </Canvas>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,12,0,0" HorizontalAlignment="Center">
            <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedBrush}" FontFamily="Segoe UI"
                       FontSize="12.5" HorizontalAlignment="Center" Text="Starting..." />
            <TextBlock Foreground="{StaticResource FaintBrush}" FontFamily="Segoe UI" FontSize="12"
                       Margin="0,3,0,0" HorizontalAlignment="Center"
                       Text="Roll the Triki controller to move your paddle (gold, right). Up / Down arrows also work." />
        </StackPanel>
    </Grid>
</Window>
