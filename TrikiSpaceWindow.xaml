<Window x:Class="TrikiPong.TrikiSpaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Triki Space" Height="720" Width="980"
        ResizeMode="CanMinimize"
        Background="{StaticResource WindowBackgroundBrush}"
        Loaded="OnWindowLoaded" Closing="OnWindowClosing"
        KeyDown="OnKeyDown" KeyUp="OnKeyUp" Focusable="True">
    <Grid Margin="20,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="&#x2190; Menu" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Left" Click="OnBackToMenuClick" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource SurfaceBorderBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="16,5" Margin="0,0,10,0">
                    <TextBlock FontFamily="Consolas" FontSize="18" FontWeight="Bold" Foreground="White">
                        <Run Text="SCORE " Foreground="#FF9298B4" FontSize="11" /><Run x:Name="ScoreText" Text="0" />
                    </TextBlock>
                </Border>
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource SurfaceBorderBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="16,5">
                    <TextBlock FontFamily="Consolas" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentCyanBrush}">
                        <Run Text="WAVE " Foreground="#FF9298B4" FontSize="11" /><Run x:Name="WaveText" Text="1" />
                    </TextBlock>
                </Border>
            </StackPanel>

            <TextBlock Grid.Column="2" x:Name="ConnStatusText" VerticalAlignment="Center"
                       FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource MutedBrush}" Text="Keyboard mode" />
        </Grid>

        <!-- Play field -->
        <Border Grid.Row="1" CornerRadius="14" BorderBrush="{StaticResource SurfaceBorderBrush}"
                BorderThickness="1.5" ClipToBounds="True"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#FF2E7BFF" BlurRadius="26" ShadowDepth="0" Opacity="0.22" />
            </Border.Effect>
            <Grid>
                <Canvas x:Name="Field" Width="900" Height="600">
                    <Canvas.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0.4,1">
                            <GradientStop Color="#FF070912" Offset="0" />
                            <GradientStop Color="#FF0C1024" Offset="1" />
                        </LinearGradientBrush>
                    </Canvas.Background>
                </Canvas>

                <!-- Damage flash -->
                <Border x:Name="DamageOverlay" BorderBrush="#FFFF3B3B" BorderThickness="0" IsHitTestVisible="False" />

                <!-- HUD bars (bottom-left) -->
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="14" Width="200"
                            IsHitTestVisible="False">
                    <TextBlock Text="HULL" Style="{StaticResource SubtitleText}" FontSize="10" />
                    <Border Height="12" CornerRadius="6" Background="#33000000" Margin="0,2,0,8">
                        <Border x:Name="HealthBar" HorizontalAlignment="Left" CornerRadius="6" Width="200">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF4DE28A" Offset="0" /><GradientStop Color="#FF9CFF6B" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Border>
                    <TextBlock Text="BOOST" Style="{StaticResource SubtitleText}" FontSize="10" />
                    <Border Height="10" CornerRadius="5" Background="#33000000" Margin="0,2,0,8">
                        <Border x:Name="BoostBar" HorizontalAlignment="Left" CornerRadius="5" Width="200" Background="#FF39D8FF" />
                    </Border>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="14" Width="200"
                            IsHitTestVisible="False">
                    <TextBlock x:Name="SuperLabel" Text="SUPER" Style="{StaticResource SubtitleText}" FontSize="10" />
                    <Border Height="10" CornerRadius="5" Background="#33000000" Margin="0,2,0,0">
                        <Border x:Name="SuperBar" HorizontalAlignment="Left" CornerRadius="5" Width="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FFFF4D8D" Offset="0" /><GradientStop Color="#FF7C5CFF" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Border>
                </StackPanel>

                <!-- Center messages -->
                <TextBlock x:Name="ToastText" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,20,0,0"
                           FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" Foreground="#FFFFC85C"
                           Visibility="Collapsed" IsHitTestVisible="False" />

                <!-- Raw BLE monitor -->
                <Border x:Name="RawMonitor" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12"
                        Background="#CC05060C" BorderBrush="{StaticResource SurfaceBorderBrush}" BorderThickness="1"
                        CornerRadius="10" Padding="12,10" Visibility="Collapsed" MaxWidth="360">
                    <StackPanel>
                        <TextBlock Text="BLE RAW MONITOR (F2)" FontFamily="Consolas" FontSize="11"
                                   Foreground="{StaticResource AccentCyanBrush}" FontWeight="Bold" Margin="0,0,0,4" />
                        <TextBlock x:Name="RawMonitorText" FontFamily="Consolas" FontSize="11"
                                   Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"
                                   Text="Waiting for packets... Connect Triki and press its button; watch which byte index changes." />
                    </StackPanel>
                </Border>

                <!-- Pause overlay -->
                <Grid x:Name="PauseOverlay" Background="#CC0A0B14" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="PAUSED" FontFamily="Segoe UI" FontSize="40" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10" />
                        <TextBlock Text="Esc to resume" Style="{StaticResource SubtitleText}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>

                <!-- How-to-play / start overlay -->
                <Grid x:Name="GuideOverlay" Background="#EE070912" Visibility="Collapsed">
                    <Border HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="560"
                            Background="#FF0C1024" BorderBrush="{StaticResource SurfaceBorderBrush}"
                            BorderThickness="1.5" CornerRadius="16" Padding="34,28">
                        <Border.Effect>
                            <DropShadowEffect Color="#FF2E7BFF" BlurRadius="30" ShadowDepth="0" Opacity="0.35" />
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="TRIKI SPACE" FontFamily="Segoe UI" FontSize="34" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#FF5CC8FF" BlurRadius="18" ShadowDepth="0" Opacity="0.8" />
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Foreground="{StaticResource MutedBrush}" FontFamily="Segoe UI" FontSize="13.5"
                                       TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,18"
                                       Text="Enemies and asteroids dive from the top and shoot back. Stay alive, slide out of the way, and blast everything above you." />

                            <TextBlock Text="HOW TO PLAY" Style="{StaticResource SubtitleText}" FontSize="11" Margin="0,0,0,8" />
                            <StackPanel Margin="4,0,0,4">
                                <TextBlock Foreground="White" FontFamily="Segoe UI" FontSize="13.5" Margin="0,3"
                                           Text="&#x1F579;  Move left / right — roll the Triki controller sideways (like the Pong paddle), or use A / D or ← / →" TextWrapping="Wrap" />
                                <TextBlock Foreground="White" FontFamily="Segoe UI" FontSize="13.5" Margin="0,3"
                                           Text="&#x1F52B;  Fire — automatic, straight up. Nothing to press." TextWrapping="Wrap" />
                                <TextBlock Foreground="White" FontFamily="Segoe UI" FontSize="13.5" Margin="0,3"
                                           Text="&#x26A1;  Boost (dodge fast) — shake the controller, or hold Left Shift" TextWrapping="Wrap" />
                                <TextBlock Foreground="White" FontFamily="Segoe UI" FontSize="13.5" Margin="0,3"
                                           Text="&#x1F4A5;  Super shot — give it one sharp hit, or press Enter (needs a full SUPER meter)" TextWrapping="Wrap" />
                                <TextBlock Foreground="White" FontFamily="Segoe UI" FontSize="13.5" Margin="0,3"
                                           Text="&#x23F8;  Pause — Esc      &#x2022;      F1 dev panel      &#x2022;      F2 BLE monitor" TextWrapping="Wrap" />
                            </StackPanel>

                            <Button Content="Start  &#x25B6;" Width="180" Height="48" Margin="0,22,0,6"
                                    Style="{StaticResource PrimaryButton}" HorizontalAlignment="Center"
                                    Click="OnStartClick" />
                            <TextBlock Text="…or press any key" Style="{StaticResource SubtitleText}"
                                       FontSize="11" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Game over overlay -->
                <Grid x:Name="GameOverOverlay" Background="#CC0A0B14" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="GAME OVER" FontFamily="Segoe UI" FontSize="46" FontWeight="Bold"
                                   Foreground="#FFFF4D6A" HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FFFF4D6A" BlurRadius="24" ShadowDepth="0" Opacity="0.8" />
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock x:Name="FinalScoreText" FontFamily="Segoe UI" FontSize="16"
                                   Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"
                                   Margin="0,10,0,22" />
                        <Button Content="&#x21BB;  Restart" Width="160" Height="46"
                                Style="{StaticResource PrimaryButton}" HorizontalAlignment="Center"
                                Click="OnRestartClick" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,10,0,0" HorizontalAlignment="Center">
            <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedBrush}" FontFamily="Segoe UI"
                       FontSize="12.5" HorizontalAlignment="Center" Text="Roll left/right to move · fires up automatically · shake = boost · sharp hit = super" />
            <TextBlock Foreground="{StaticResource FaintBrush}" FontFamily="Segoe UI" FontSize="11.5"
                       Margin="0,3,0,0" HorizontalAlignment="Center"
                       Text="Keyboard: A/D or ←/→ move · Shift boost · Enter super · Esc pause · F1 dev panel · F2 BLE monitor" />
        </StackPanel>
    </Grid>
</Window>
