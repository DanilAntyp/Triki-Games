<Window x:Class="TrikiPong.DeveloperPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Triki Space — Dev Panel" Height="760" Width="420"
        ResizeMode="CanResize" WindowStartupLocation="Manual"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="DEV PANEL" Style="{StaticResource TitleText}" FontSize="20" Margin="0,0,0,8" />

        <Border Grid.Row="1" Background="#CC05060C" BorderBrush="{StaticResource SurfaceBorderBrush}"
                BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,0,0,10">
            <TextBlock x:Name="DiagnosticsText" FontFamily="Consolas" FontSize="11.5"
                       Foreground="{StaticResource MutedBrush}" Text="Waiting for data..." />
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="SlidersHost" />
        </ScrollViewer>

        <Border Grid.Row="3" BorderBrush="{StaticResource SurfaceBorderBrush}" BorderThickness="0,1,0,0"
                Padding="0,10,0,0" Margin="0,8,0,0">
            <WrapPanel x:Name="ButtonsHost" />
        </Border>
    </Grid>
</Window>
