<Window x:Class="TrikiPong.TrafficRacerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Triki Traffic Racer" Height="580" Width="880"
        ResizeMode="CanMinimize"
        Background="{StaticResource WindowBackgroundBrush}"
        Loaded="OnWindowLoaded" Closing="OnWindowClosing"
        KeyDown="OnKeyDown" KeyUp="OnKeyUp" Focusable="True">
    <Grid Margin="20,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- HUD -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="&#x2190; Menu" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Left" Click="OnBackToMenuClick" />

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource SurfaceBorderBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="18,6" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="DISTANCE" FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource FaintBrush}" HorizontalAlignment="Center" />
                        <TextBlock FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Center">
                            <Run x:Name="DistanceText" Text="0" /><Run Text=" m" FontSize="13" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource SurfaceBorderBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="18,6" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="SPEED" FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource FaintBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="SpeedText" Text="0" FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource SurfaceBorderBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="18,6">
                    <StackPanel>
                        <TextBlock Text="DODGED" FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource FaintBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="DodgedText" Text="0" FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource AccentPinkBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" CornerRadius="14" BorderBrush="{StaticResource SurfaceBorderBrush}"
                BorderThickness="1.5" ClipToBounds="True"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#FF7C5CFF" BlurRadius="26" ShadowDepth="0" Opacity="0.22" />
            </Border.Effect>
            <Grid>
                <!-- Scene layers are built and updated in code-behind -->
                <Canvas x:Name="Court" Width="800" Height="440" ClipToBounds="True">
                    <Canvas.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FF160B33" Offset="0" />
                            <GradientStop Color="#FF3A1D63" Offset="0.20" />
                            <GradientStop Color="#FF7A2E77" Offset="0.30" />
                            <GradientStop Color="#FFFF8A5B" Offset="0.345" />
                            <GradientStop Color="#FF12283A" Offset="0.346" />
                            <GradientStop Color="#FF0A1524" Offset="1" />
                        </LinearGradientBrush>
                    </Canvas.Background>
                </Canvas>

                <Grid x:Name="CrashOverlay" Background="#CC0A0B14" Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="CRASHED" FontFamily="Segoe UI" FontSize="46" FontWeight="Bold"
                                   Foreground="#FFFF4D6A" HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FFFF4D6A" BlurRadius="24" ShadowDepth="0" Opacity="0.8" />
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock x:Name="FinalScoreText" FontFamily="Segoe UI" FontSize="15"
                                   Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"
                                   Margin="0,10,0,22" />
                        <Button Content="&#x21BB;  Restart" Width="160" Height="46"
                                Style="{StaticResource PrimaryButton}" HorizontalAlignment="Center"
                                Click="OnRestartClick" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,12,0,0" HorizontalAlignment="Center">
            <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedBrush}" FontFamily="Segoe UI"
                       FontSize="12.5" HorizontalAlignment="Center" Text="Starting..." />
            <TextBlock Foreground="{StaticResource FaintBrush}" FontFamily="Segoe UI" FontSize="12"
                       Margin="0,3,0,0" HorizontalAlignment="Center"
                       Text="Roll the Triki controller to steer. Left / Right arrows also work. Dodge the oncoming traffic." />
        </StackPanel>
    </Grid>
</Window>
