<Window x:Class="TrikiPong.MainMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Triki Arcade" Height="720" Width="540"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}"
        Closing="OnWindowClosing">
    <Grid Margin="44,36">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,26">
            <TextBlock Text="TRIKI ARCADE" Style="{StaticResource TitleText}" HorizontalAlignment="Center" />
            <TextBlock Text="Select a game" Style="{StaticResource SubtitleText}"
                       HorizontalAlignment="Center" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Game cards -->
        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            <Button x:Name="PongButton" Style="{StaticResource CardButton}" Click="OnPongClick" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="58" Height="58" CornerRadius="14"
                            Background="#FF10233A" VerticalAlignment="Center" Margin="0,0,18,0">
                        <TextBlock Text="&#x1F3D3;" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Triki Pong" FontFamily="Segoe UI" FontSize="19" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="Roll to volley against the AI" FontFamily="Segoe UI" FontSize="12.5"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="&#x2192;" FontSize="22" VerticalAlignment="Center"
                               Foreground="{StaticResource FaintBrush}" />
                </Grid>
            </Button>

            <Button x:Name="RacerButton" Style="{StaticResource CardButton}" Click="OnRacerClick" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="58" Height="58" CornerRadius="14"
                            Background="#FF34122B" VerticalAlignment="Center" Margin="0,0,18,0">
                        <TextBlock Text="&#x1F3CE;" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Endless Traffic Racer" FontFamily="Segoe UI" FontSize="19" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="Steer through oncoming traffic" FontFamily="Segoe UI" FontSize="12.5"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="&#x2192;" FontSize="22" VerticalAlignment="Center"
                               Foreground="{StaticResource FaintBrush}" />
                </Grid>
            </Button>

            <Button x:Name="SpaceButton" Style="{StaticResource CardButton}" Click="OnSpaceClick">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="58" Height="58" CornerRadius="14"
                            Background="#FF241040" VerticalAlignment="Center" Margin="0,0,18,0">
                        <TextBlock Text="&#x1F680;" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Triki Space" FontFamily="Segoe UI" FontSize="19" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="Tilt to fly, rotate to aim, shake to boost" FontFamily="Segoe UI" FontSize="12.5"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="&#x2192;" FontSize="22" VerticalAlignment="Center"
                               Foreground="{StaticResource FaintBrush}" />
                </Grid>
            </Button>
        </StackPanel>

        <!-- Footer -->
        <StackPanel Grid.Row="2">
            <Button x:Name="SettingsButton" Content="&#x2699;  Settings" HorizontalAlignment="Center"
                    Click="OnSettingsClick" />
            <Border Background="#22000000" CornerRadius="10" Padding="14,10" Margin="0,18,0,0">
                <StackPanel>
                    <TextBlock x:Name="StatusText" Text="" FontFamily="Segoe UI" FontSize="12"
                               Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" />
                    <TextBlock x:Name="DeviceInfoText" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,3,0,0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
