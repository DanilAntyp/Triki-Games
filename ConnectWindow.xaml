<Window x:Class="TrikiPong.ConnectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Triki Arcade" Height="560" Width="520"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}"
        Closing="OnWindowClosing">
    <Grid Margin="48,44">
        <StackPanel VerticalAlignment="Center">

            <!-- Emblem -->
            <Border Width="76" Height="76" CornerRadius="20" HorizontalAlignment="Center"
                    Background="{StaticResource AccentGradient}" Margin="0,0,0,22">
                <Border.Effect>
                    <DropShadowEffect Color="#FF2E7BFF" BlurRadius="30" ShadowDepth="0" Opacity="0.6" />
                </Border.Effect>
                <TextBlock Text="&#x1F3AE;" FontSize="38" HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <TextBlock Text="TRIKI ARCADE" Style="{StaticResource TitleText}"
                       HorizontalAlignment="Center" Margin="0,0,0,6" />
            <TextBlock Text="Connect your Triki motion controller to play"
                       Style="{StaticResource SubtitleText}" HorizontalAlignment="Center"
                       Margin="0,0,0,34" />

            <Button x:Name="ConnectButton" Content="Connect Controller" Height="50"
                    Style="{StaticResource PrimaryButton}" Click="OnConnectClick" />

            <Border Background="#22000000" CornerRadius="12" Padding="16,12" Margin="0,18,0,0">
                <StackPanel>
                    <TextBlock x:Name="StatusText" Text="Not connected." FontFamily="Segoe UI" FontSize="12.5"
                               Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" />
                    <TextBlock x:Name="DeviceInfoText" FontFamily="Segoe UI" FontSize="12.5" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Button x:Name="StartGameButton" Content="Continue &#x2192;" Height="50"
                    Style="{StaticResource PrimaryButton}" Margin="0,20,0,0"
                    IsEnabled="False" Click="OnStartGameClick" />

            <Button x:Name="SkipButton" Content="Play without controller (keyboard only)"
                    Style="{StaticResource GhostButton}" Margin="0,12,0,0"
                    HorizontalAlignment="Center" Click="OnSkipClick" />
        </StackPanel>
    </Grid>
</Window>
