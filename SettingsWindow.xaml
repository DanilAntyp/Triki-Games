<Window x:Class="TrikiPong.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="340" Width="460"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}"
        Closing="OnWindowClosing">
    <Grid Margin="36,30">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="SETTINGS" Style="{StaticResource TitleText}" FontSize="26"
                       HorizontalAlignment="Center" Margin="0,0,0,26" />

            <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource SurfaceBorderBrush}"
                    BorderThickness="1" CornerRadius="14" Padding="22,18">
                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="Controller sensitivity" FontFamily="Segoe UI" FontSize="14"
                                   FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                                   HorizontalAlignment="Left" />
                        <Border HorizontalAlignment="Right" Background="#FF10233A" CornerRadius="8"
                                Padding="10,3">
                            <TextBlock x:Name="SensitivityValueText" FontFamily="Consolas" FontSize="14"
                                       FontWeight="Bold" Foreground="{StaticResource AccentCyanBrush}" Text="1.0x" />
                        </Border>
                    </Grid>

                    <Slider x:Name="SensitivitySlider" Style="{StaticResource NeonSlider}"
                            Minimum="0.4" Maximum="2.5" TickFrequency="0.1"
                            IsSnapToTickEnabled="True" Margin="0,12,0,6"
                            ValueChanged="OnSensitivityChanged" />

                    <Grid>
                        <TextBlock Text="Gentle" Style="{StaticResource SubtitleText}" FontSize="11"
                                   HorizontalAlignment="Left" />
                        <TextBlock Text="Twitchy" Style="{StaticResource SubtitleText}" FontSize="11"
                                   HorizontalAlignment="Right" />
                    </Grid>
                </StackPanel>
            </Border>

            <Button Content="Done" Height="44" Style="{StaticResource PrimaryButton}"
                    Margin="0,24,0,0" Click="OnDoneClick" />
        </StackPanel>
    </Grid>
</Window>
